{
  "name": "forge",
  "type": "module",
  "private": true,
  "description": "A voxel editor",
  "license": "MIT",
  "author": "Agni <a@a4n1.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/a4n1/vyas.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "pnpm run build:wasm && pnpm run build:web",
    "build:wasm": "sh ./scripts/build-wasm.sh",
    "build:web": "vite build",
    "start": "vite start",
    "preview": "pnpm build && wrangler dev --config wrangler.toml",
    "deploy": "pnpm build && wrangler deploy --config wrangler.toml",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "2.0.0-alpha.2",
    "@solidjs/vite-plugin-nitro-2": "^0.1.0",
    "solid-js": "^1.9.5",
    "vite": "^7.0.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "wasm-pack": "^0.15.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "prettier": "^3.9.4",
    "wrangler": "^4.107.1"
  },
  "engines": {
    "node": ">=22"
  }
}
